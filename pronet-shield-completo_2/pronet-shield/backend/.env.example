# ── SERVIDOR ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://shield.pronetprogramacao.com.br

# ── JWT ──────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UMA_CHAVE_FORTE_AQUI
JWT_REFRESH_SECRET=GERE_OUTRA_CHAVE_FORTE_AQUI
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SUPABASE ─────────────────────────────────────────────────
# Em: supabase.com → Project Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...sua_service_role_key

# ── EMAIL (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua_senha_de_app_gmail
ALERT_EMAIL=alertas@pronetprogramacao.com.br

# ── DISCORD WEBHOOK ──────────────────────────────────────────
# Servidor Discord → Integrações → Webhooks → Copiar URL
DISCORD_WEBHOOK=https://discord.com/api/webhooks/ID/TOKEN

# ── WHATSAPP (opcional — via Z-API ou Twilio) ────────────────
# WHATSAPP_TOKEN=seu_token
# WHATSAPP_INSTANCE=sua_instancia

# ── IA (Anthropic) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...sua_chave

# ── SEGURANÇA ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
